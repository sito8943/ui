{
  "name": "@sito/ui",
  "private": false,
  "version": "0.3.0",
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SitoNumbis/ui.git"
  },
  "main": "./dist/ui.cjs",
  "module": "./dist/ui.js",
  "types": "./dist/ui.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js",
      "require": "./dist/ui.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./theme.css": "./dist/theme.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --base=./",
    "lint": "oxlint --type-aware --max-warnings 0",
    "lint:fix": "oxlint --type-aware --fix --max-warnings 0",
    "format": "prettier . --write",
    "preview": "vite preview"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "overrides": {
    "@microsoft/api-extractor": "7.58.9",
    "ajv": "6.15.0",
    "brace-expansion": "1.1.16",
    "cross-spawn": "7.0.6",
    "flatted": "3.4.2",
    "lodash": "4.18.1",
    "minimatch": "3.1.5",
    "validator": "13.15.35"
  },
  "pnpm": {
    "overrides": {
      "@microsoft/api-extractor": "7.58.9",
      "ajv": "6.15.0",
      "brace-expansion": "1.1.16",
      "cross-spawn": "7.0.6",
      "flatted": "3.4.2",
      "lodash": "4.18.1",
      "minimatch": "3.1.5",
      "validator": "13.15.35"
    }
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/typescript6": "^6.0.2",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.5.2",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "prettier": "3.9.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vite-plugin-dts": "5.0.3"
  }
