{
  "name": "@sito/ui",
  "private": false,
  "version": "0.0.203",
  "type": "module",
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SitoNumbis/ui.git"
  },
  "main": "./dist/ui.cjs",
  "module": "./dist/ui.js",
  "types": "./dist/ui.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js",
      "require": "./dist/ui.cjs"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --base=./",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@emotion/css": "11.13.5",
    "react-error-boundary": "6.1.2"
  },
  "overrides": {
    "@microsoft/api-extractor": "7.58.9",
    "ajv": "6.15.0",
    "brace-expansion": "1.1.16",
    "cross-spawn": "7.0.6",
    "flatted": "3.4.2",
    "lodash": "4.18.1",
    "minimatch": "3.1.5",
    "validator": "13.15.35"
  },
  "devDependencies": {
    "@types/node": "20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.5.2",
    "eslint": "8.57.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vite-plugin-dts": "5.0.3",
    "vite-plugin-lib-inject-css": "2.2.2"
  }
}
